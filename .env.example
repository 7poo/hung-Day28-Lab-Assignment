# Lab 28 environment variables
#
# Replace these placeholders after you start the vLLM / embedding services
# on Kaggle or Colab and expose them with ngrok or cloudflared.

# vLLM OpenAI-compatible server URL.
# Examples:
#   https://xxxx.ngrok-free.app
#   https://xxxx.trycloudflare.com
VLLM_NGROK_URL=https://replace-with-your-vllm-tunnel-url.ngrok-free.app

# Embedding service URL. Required by scripts/05_embed_to_qdrant.py.
# Leave as a placeholder until you expose the embedding service.
EMBED_NGROK_URL=https://replace-with-your-embed-tunnel-url.ngrok-free.app

# LangSmith API key. Required only for scripts/09_verify_observability.py.
LANGCHAIN_API_KEY=replace-with-your-langsmith-api-key

# LangSmith project used by the lab docs and observability checks.
LANGCHAIN_PROJECT=lab28-platform
